    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.gaussian_process import GaussianProcessRegressor\n",
    "from sklearn.gaussian_process.kernels import ConstantKernel, RBF, WhiteKernel\n",
    "\n",
    "%load_ext autoreload\n",
    "%autoreload 2\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ==================== 1) Synthetic functions & sampling ====================\n",
    "def f_good(X):\n",
    "    X = np.atleast_2d(X)\n",
    "    x1, x2 = X[:, 0], X[:, 1]\n",
    "    return 1.5 * np.sin(np.pi * x1) + 0.25 * x1**2 + 0.8 * np.cos(np.pi * x2)\n",
    "\n",
    "\n",
    "def f_bad_int(X):\n",
    "    X = np.atleast_2d(X)\n",
    "    x1, x2 = X[:, 0], X[:, 1]\n",
    "    return np.sin(np.pi * x1 * x2) + 0.25 * x1\n",
    "\n",
    "\n",
    "def f_bad_corr(X):\n",
    "    X = np.atleast_2d(X)\n",
    "    x1, x2 = X[:, 0], X[:, 1]\n",
    "    return np.exp(-5.0 * (x1 - x2) ** 2) + 0.2 * np.sin(2 * np.pi * (x1 + x2))\n",
    "\n",
    "\n",
    "def sample_inputs(func_name, n=1200, seed=42):\n",
    "    rng = np.random.default_rng(seed)\n",
    "    if func_name in (\"f_good\", \"f_bad_int\"):\n",
    "        return rng.uniform(-2, 2, size=(n, 2))\n",
    "    x1 = rng.uniform(-2, 2, size=n)\n",
    "    eta = rng.normal(0.0, 0.1, size=n)\n",
    "    x2 = x1 + eta\n",
    "    return np.column_stack([x1, x2])\n",
    "\n",
    "\n",
    "# ==================== 2) ALE utilities (ACE notebook: ICE/PDP -> ALE) ====================\n",
    "def q_edges(x, n_bins=20):\n",
    "    e = np.quantile(x, np.linspace(0, 1, n_bins + 1))\n",
    "    e = np.unique(e)\n",
    "    if len(e) < 3:\n",
    "        lo, hi = np.min(x), np.max(x)\n",
    "        e = np.linspace(lo, hi + 1e-6, max(n_bins, 2) + 1)\n",
    "    return e\n",
    "\n",
    "\n",
    "def bindex(x, edges):\n",
    "    return np.clip(np.searchsorted(edges, x, side='right') - 1, 0, len(edges) - 2)\n",
    "\n",
    "\n",
    "def ale_1d(predictor, X, feat, n_bins=20):\n",
    "    edges = q_edges(X[:, feat], n_bins)\n",
    "    idx = bindex(X[:, feat], edges)\n",
    "    k = len(edges) - 1\n",
    "    diffs = np.zeros(k)\n",
    "    counts = np.zeros(k, dtype=int)\n",
    "    for b in range(k):\n",
    "        m = idx == b\n",
    "        counts[b] = m.sum()\n",
    "        if counts[b] == 0:\n",
    "            continue\n",
    "        X0, X1 = X[m].copy(), X[m].copy()\n",
    "        X0[:, feat] = edges[b]\n",
    "        X1[:, feat] = edges[b + 1]\n",
    "        diffs[b] = np.mean(predictor(X1) - predictor(X0))\n",
    "    cum = np.concatenate([[0.0], np.cumsum(diffs)])\n",
    "    mids = 0.5 * (edges[:-1] + edges[1:])\n",
    "    eff = 0.5 * (cum[:-1] + cum[1:])\n",
    "    eff = eff - np.mean(eff[idx])\n",
    "    return mids, eff, counts\n",
    "\n",
    "\n",
    "def ale_2d_interaction(predictor, X, bins1=20, bins2=20, empty_policy='mask'):\n",
    "    e1 = q_edges(X[:, 0], bins1)\n",
    "    e2 = q_edges(X[:, 1], bins2)\n",
    "    i1, i2 = bindex(X[:, 0], e1), bindex(X[:, 1], e2)\n",
    "    k1, k2 = len(e1) - 1, len(e2) - 1\n",
    "    local = np.zeros((k1, k2))\n",
    "    cnt = np.zeros((k1, k2), dtype=int)\n",
    "\n",
    "    for a in range(k1):\n",
    "        for b in range(k2):\n",
    "            m = (i1 == a) & (i2 == b)\n",
    "            n = m.sum()\n",
    "            cnt[a, b] = n\n",
    "            if n == 0:\n",
    "                continue\n",
    "            x1_lo, x1_hi = e1[a], e1[a + 1]\n",
    "            x2_lo, x2_hi = e2[b], e2[b + 1]\n",
    "            X00 = X[m].copy(); X00[:, 0], X00[:, 1] = x1_lo, x2_lo\n",
    "            X10 = X[m].copy(); X10[:, 0], X10[:, 1] = x1_hi, x2_lo\n",
    "            X01 = X[m].copy(); X01[:, 0], X01[:, 1] = x1_lo, x2_hi\n",
    "            X11 = X[m].copy(); X11[:, 0], X11[:, 1] = x1_hi, x2_hi\n",
    "            local[a, b] = np.mean(predictor(X11) - predictor(X10) - predictor(X01) + predictor(X00))\n",
    "\n",
    "    raw = np.cumsum(np.cumsum(local, axis=0), axis=1)\n",
    "    w = cnt.astype(float)\n",
    "    valid = w > 0\n",
    "    if empty_policy == 'zero':\n",
    "        valid[:] = True\n",
    "        w = np.where(w > 0, w, 1.0)\n",
    "\n",
    "    h = raw.copy(); h[~valid] = 0.0\n",
    "    h -= np.sum(w * h) / np.sum(w)\n",
    "    for _ in range(30):\n",
    "        r = np.divide(np.sum(w * h, axis=1), np.sum(w, axis=1), out=np.zeros(k1), where=np.sum(w, axis=1) > 0)\n",
    "        h = h - r[:, None]\n",
    "        c = np.divide(np.sum(w * h, axis=0), np.sum(w, axis=0), out=np.zeros(k2), where=np.sum(w, axis=0) > 0)\n",
    "        h = h - c[None, :]\n",
    "        h -= np.sum(w * h) / np.sum(w)\n",
    "\n",
    "    if empty_policy == 'mask':\n",
    "        h = np.where(valid, h, np.nan)\n",
    "\n",
    "    g1 = 0.5 * (e1[:-1] + e1[1:])\n",
    "    g2 = 0.5 * (e2[:-1] + e2[1:])\n",
    "    return g1, g2, h, cnt\n",
    "\n",
    "\n",
    "def fit_gp(X, y):\n",
    "    kernel = ConstantKernel(1.0, (1e-3, 1e3)) * RBF([1.0, 1.0], (1e-2, 1e2)) + WhiteKernel(1e-3, (1e-6, 1e-1))\n",
    "    gp = GaussianProcessRegressor(kernel=kernel, normalize_y=True, random_state=0, n_restarts_optimizer=3)\n",
    "    gp.fit(X, y)\n",
    "    return gp\n"
   ]
