    "# ==================== 3) Run demo (ACE/ALE view) ====================\n",
    "func_name = 'f_good'  # 'f_good' / 'f_bad_int' / 'f_bad_corr'\n",
    "func_map = {'f_good': f_good, 'f_bad_int': f_bad_int, 'f_bad_corr': f_bad_corr}\n",
    "f = func_map[func_name]\n",
    "\n",
    "X = sample_inputs(func_name, n=1200, seed=42)\n",
    "y = f(X)\n",
    "gp = fit_gp(X, y)\n",
    "\n",
    "predictors = {\n",
    "    'true': lambda Z: f(Z),\n",
    "    'gp_mean': lambda Z: gp.predict(Z, return_std=False),\n",
    "}\n",
    "\n",
    "fig, axs = plt.subplots(2, 3, figsize=(15, 9))\n",
    "fig.suptitle(f'ACE(ALE) notebook - {func_name}')\n",
    "\n",
    "axs[0, 0].scatter(X[:, 0], X[:, 1], s=8, alpha=0.4)\n",
    "axs[0, 0].set_title('input scatter')\n",
    "\n",
    "for row, (name, pred) in enumerate(predictors.items()):\n",
    "    g1, A1, _ = ale_1d(pred, X, feat=0, n_bins=20)\n",
    "    g2, A2, _ = ale_1d(pred, X, feat=1, n_bins=20)\n",
    "    gx, gy, A12, cnt = ale_2d_interaction(pred, X, bins1=20, bins2=20, empty_policy='mask')\n",
    "\n",
    "    axs[row, 1].plot(g1, A1, label='A1(x1)')\n",
    "    axs[row, 1].plot(g2, A2, label='A2(x2)')\n",
    "    axs[row, 1].set_title(f'{name}: ALE main effects')\n",
    "    axs[row, 1].legend()\n",
    "\n",
    "    im = axs[row, 2].imshow(\n",
    "        A12.T,\n",
    "        origin='lower',\n",
    "        aspect='auto',\n",
    "        extent=[gx[0], gx[-1], gy[0], gy[-1]],\n",
    "        cmap='coolwarm'\n",
    "    )\n",
    "    axs[row, 2].set_title(f'{name}: A12 interaction (mask off-support)')\n",
    "    plt.colorbar(im, ax=axs[row, 2], fraction=0.046, pad=0.04)\n",
    "\n",
    "for ax in axs.ravel():\n",
    "    ax.grid(alpha=0.2)\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  }
